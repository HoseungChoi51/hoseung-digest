# Reddit OAuth app settings.
# Create an app at https://www.reddit.com/prefs/apps and choose "web app".
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=http://127.0.0.1:3847/oauth/reddit/callback
REDDIT_USER_AGENT=linux:reddit-digest:v0.1.0 (by /u/YOUR_USERNAME)

# Optional. If missing, digests are generated without AI summaries.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
